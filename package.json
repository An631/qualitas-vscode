{
  "name": "qualitas-vscode",
  "displayName": "Qualitas",
  "description": "Real-time code quality scores, refactoring flags, and improvement suggestions inline — powered by qualitas",
  "version": "0.1.16",
  "publisher": "qualitas",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "code-quality",
    "complexity",
    "refactoring",
    "metrics",
    "static-analysis"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "homepage": "https://github.com/An631/qualitas-vscode#readme",
  "bugs": {
    "url": "https://github.com/An631/qualitas-vscode/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/An631/qualitas-vscode.git"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "qualitas.analyzeFile",
        "title": "Qualitas: Analyze Current File"
      },
      {
        "command": "qualitas.analyzeFolder",
        "title": "Qualitas: Analyze Folder"
      },
      {
        "command": "qualitas.showReport",
        "title": "Qualitas: Show Report"
      },
      {
        "command": "qualitas.fixAllWithAI",
        "title": "Qualitas: Fix All Issues with AI"
      }
    ],
    "configuration": {
      "title": "Qualitas",
      "properties": {
        "qualitas.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Qualitas analysis"
        },
        "qualitas.analyzeOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run analysis when a file is saved"
        },
        "qualitas.analyzeOnChange": {
          "type": "boolean",
          "default": true,
          "description": "Run analysis as you type (debounced)"
        },
        "qualitas.changeDelay": {
          "type": "number",
          "default": 1000,
          "minimum": 200,
          "description": "Debounce delay in milliseconds for on-change analysis"
        },
        "qualitas.showInlineScores": {
          "type": "boolean",
          "default": true,
          "description": "Show inline score badges next to function names"
        },
        "qualitas.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show file quality score in the status bar"
        },
        "qualitas.scoreThreshold": {
          "type": "number",
          "default": 65,
          "minimum": 0,
          "maximum": 100,
          "description": "Minimum quality score (0-100) for displaying squiggles. Functions and classes scoring below this are flagged in the editor. Analysis rules (profile, weights, flags) are configured in qualitas.config.js."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.js --production",
    "test": "jest",
    "verify": "npm run lint && npm run test && npm run format:check && npm run quality",
    "lint": "tsc --noEmit && eslint src/ test/",
    "format": "node scripts/format.js",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "quality": "qualitas ./ -f detail",
    "quality:summary": "qualitas ./ -f summary",
    "quality:flagged": "qualitas ./ -f flagged",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --allow-missing-repository",
    "publish": "vsce publish",
    "changeset": "changeset && git add .changeset/* && git commit .changeset/*.md -m \"Added changeset file\"",
    "changeset:check": "changeset status --since=origin/main",
    "version:bump": "bash scripts/version.sh"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "eslint": "^10.0.3",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "qualitas": "^0.2.4"
  },
  "optionalDependencies": {
    "@qualitas/binding-darwin-arm64": "^0.2.4",
    "@qualitas/binding-darwin-x64": "^0.2.4",
    "@qualitas/binding-linux-arm64-gnu": "^0.2.4",
    "@qualitas/binding-linux-x64-gnu": "^0.2.4",
    "@qualitas/binding-win32-x64-msvc": "^0.2.4"
  }
}
