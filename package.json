{
  "name": "qualitas-vscode",
  "displayName": "Qualitas",
  "description": "Real-time code quality scores, refactoring flags, and improvement suggestions inline — powered by qualitas",
  "version": "0.1.5",
  "publisher": "qualitas",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "code-quality",
    "complexity",
    "refactoring",
    "metrics",
    "static-analysis"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/An631/qualitas-vscode"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "qualitas.analyzeFile",
        "title": "Qualitas: Analyze Current File"
      },
      {
        "command": "qualitas.analyzeWorkspace",
        "title": "Qualitas: Analyze Workspace"
      },
      {
        "command": "qualitas.showReport",
        "title": "Qualitas: Show Report"
      },
      {
        "command": "qualitas.fixAllWithAI",
        "title": "Qualitas: Fix All Issues with AI"
      }
    ],
    "configuration": {
      "title": "Qualitas",
      "properties": {
        "qualitas.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Qualitas analysis"
        },
        "qualitas.analyzeOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run analysis when a file is saved"
        },
        "qualitas.analyzeOnChange": {
          "type": "boolean",
          "default": true,
          "description": "Run analysis as you type (debounced)"
        },
        "qualitas.changeDelay": {
          "type": "number",
          "default": 1000,
          "minimum": 200,
          "description": "Debounce delay in milliseconds for on-change analysis"
        },
        "qualitas.showInlineScores": {
          "type": "boolean",
          "default": true,
          "description": "Show inline score badges next to function names"
        },
        "qualitas.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show file quality score in the status bar"
        },
        "qualitas.scoreThreshold": {
          "type": "number",
          "default": 65,
          "minimum": 0,
          "maximum": 100,
          "description": "Minimum acceptable quality score (0-100). Functions and classes scoring below this are flagged."
        },
        "qualitas.profile": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "cc-focused",
            "data-focused",
            "strict"
          ],
          "enumDescriptions": [
            "Balanced weights across all 5 quality pillars",
            "Emphasizes cognitive flow complexity",
            "Emphasizes data complexity (Halstead metrics)",
            "Tighter thresholds across all metrics"
          ],
          "description": "Analysis profile that controls metric weights and thresholds."
        },
        "qualitas.includeTests": {
          "type": "boolean",
          "default": false,
          "description": "Include test files in workspace analysis."
        },
        "qualitas.weights": {
          "type": "object",
          "default": {},
          "properties": {
            "cognitiveFlow": {
              "type": "number",
              "description": "Weight for cognitive flow complexity (CFC)"
            },
            "dataComplexity": {
              "type": "number",
              "description": "Weight for data complexity (Halstead)"
            },
            "identifierReference": {
              "type": "number",
              "description": "Weight for identifier reference complexity (IRC)"
            },
            "dependencyCoupling": {
              "type": "number",
              "description": "Weight for dependency coupling (DC)"
            },
            "structural": {
              "type": "number",
              "description": "Weight for structural metrics (LOC, params, nesting)"
            }
          },
          "additionalProperties": false,
          "description": "Custom weights for the 5 quality pillars. Overrides the selected profile. Values should sum to 1.0."
        },
        "qualitas.flagOverrides": {
          "type": "object",
          "default": {},
          "description": "Override flag thresholds per metric. Set to false to disable a flag, or {\"warn\": N, \"error\": M} to customize thresholds. Keys: HIGH_COGNITIVE_FLOW, HIGH_DATA_COMPLEXITY, HIGH_IDENTIFIER_CHURN, TOO_MANY_PARAMS, TOO_LONG, DEEP_NESTING, HIGH_COUPLING, EXCESSIVE_RETURNS, HIGH_HALSTEAD_EFFORT.",
          "additionalProperties": {
            "oneOf": [
              {
                "type": "boolean"
              },
              {
                "type": "object",
                "properties": {
                  "warn": {
                    "type": "number"
                  },
                  "error": {
                    "type": "number"
                  }
                },
                "required": [
                  "warn",
                  "error"
                ]
              }
            ]
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.js --production",
    "test": "jest",
    "verify": "npm run lint && npm run test && npm run quality && npm run changeset:check",
    "lint": "tsc --noEmit",
    "quality": "qualitas ./ -f detail",
    "quality:summary": "qualitas ./ -f summary",
    "quality:flagged": "qualitas ./ -f flagged",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --allow-missing-repository",
    "publish": "vsce publish",
    "changeset": "changeset",
    "changeset:check": "changeset status --since=origin/main",
    "version:bump": "changeset version"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "qualitas": "^0.1.8"
  }
}
